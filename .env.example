# ===========================================
# ZhiYu Environment Variables Template
# ===========================================
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git.

# -------------------------------------------
# Backend Server
# -------------------------------------------
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:8080,http://127.0.0.1:8080
DATABASE_PATH=/data/zhiyu.db
DATABASE_URL=postgresql://zhiyu:zhiyu_password@postgres:5432/zhiyu

# -------------------------------------------
# PostgreSQL Container
# -------------------------------------------
POSTGRES_DB=zhiyu
POSTGRES_USER=zhiyu
POSTGRES_PASSWORD=change_this_password

# -------------------------------------------
# Frontend (Browser API Base URL)
# -------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -------------------------------------------
# Tencent Hunyuan LLM
# -------------------------------------------
HUNYUAN_API_KEY=
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_MODEL=hunyuan-lite

# -------------------------------------------
# Dify Dataset Retrieval
# -------------------------------------------
DIFY_API_URL=http://localhost:3000/v1
DIFY_API_KEY=
DIFY_DATASET_ID=
USE_DIFY_RETRIEVAL=false

# -------------------------------------------
# RAGFlow Retrieval
# -------------------------------------------
RAGFLOW_API_URL=http://localhost:9380/api/v1
RAGFLOW_API_KEY=
RAGFLOW_KB_ID=
USE_RAGFLOW_RETRIEVAL=false
